<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Finance Dashboard</title>
  <style>
    /* Reset margin and padding */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: sans-serif;
    }

    body {
      background-color: #1f1f2e; /* Dark background */
      color: #fff;
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar */
    .sidebar {
      width: 250px;
      background-color: #29293d; 
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .sidebar h2 {
      font-size: 1.2rem;
      margin-bottom: 10px;
    }

    .sidebar nav ul {
      list-style-type: none;
    }

    .sidebar nav ul li {
      padding: 10px 0;
      cursor: pointer;
      color: #ccc;
      transition: color 0.3s;
    }

    .sidebar nav ul li:hover,
    .sidebar nav ul li.active {
      color: #ff0077; /* Highlight color */
    }

    /* Main Content */
    .main-content {
      flex: 1;
      padding: 20px;
    }

    .main-content header {
      font-size: 1.5rem;
      margin-bottom: 20px;
      color: #ff0077; /* Highlight color for heading */
    }

    .cards-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }

    /* Individual Card */
    .card {
      background-color: #2e2e40;
      border-radius: 10px;
      padding: 20px;
    }

    .card h3 {
      margin-bottom: 10px;
      font-size: 1.1rem;
      color: #ff0077; 
    }

    .card p {
      margin-bottom: 8px;
      color: #ccc;
    }

    /* Example "Report" or "Graph" style boxes */
    .report-box {
      background-color: #2e2e40;
      border-radius: 10px;
      padding: 20px;
      margin-top: 20px;
    }

    .report-box h3 {
      color: #ff0077; 
    }

    .report-content {
      margin-top: 10px;
      color: #ccc;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .sidebar {
        width: 200px;
      }

      .cards-container {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <!-- SIDEBAR -->
  <div class="sidebar">
    <h2>Rohan Mishra</h2>
    <nav>
      <ul>
        <li class="active">Home</li>
        <li>Budget</li>
        <li>Transactions</li>
        <li>Subscriptions</li>
        <li>Loans</li>
        <li>Reports</li>
        <li>Savings</li>
        <li>Financial Advice</li>
        <li>Account</li>
        <li>Settings</li>
      </ul>
    </nav>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main-content">
    <header>Home</header>
    
    <!-- CARDS / DASHBOARD SECTION -->
    <div class="cards-container">
      <!-- Cards Section -->
      <div class="card">
        <h3>Cards</h3>
        <p>Card 1 (**** **** **** 1234)</p>
        <p>Card 2 (**** **** **** 5678)</p>
      </div>

      <div class="card">
        <h3>Budget</h3>
        <p>Cash: $2000</p>
        <p>Credit: $1500</p>
      </div>

      <div class="card">
        <h3>All Transactions</h3>
        <p>Groceries: -$50</p>
        <p>Salary: +$2000</p>
      </div>

      <div class="card">
        <h3>Subscriptions</h3>
        <p>Netflix: $15/month</p>
        <p>Spotify: $10/month</p>
      </div>
    </div>

    <!-- REPORT / GRAPH SECTION -->
    <div class="report-box">
      <h3>Report</h3>
      <div class="report-content">
        <p>Overall spending this month is up 10% from last month.</p>
        <p>Projected savings: $500</p>
      </div>
    </div>
  </div>
</body>
</html>